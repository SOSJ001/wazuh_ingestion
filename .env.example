# Manager API (connectivity check). Default: wazuh/wazuh
WAZUH_IP=192.168.56.103
WAZUH_USER=wazuh
WAZUH_PASS=wazuh

# Indexer (alerts). OVA default: admin/admin
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=admin

# SSH tunnel to server (indexer is on server localhost). OVA default: wazuh-user / wazuh
WAZUH_SSH_USER=wazuh-user
WAZUH_SSH_PASS=wazuh

# Live mode: seconds between each poll (default 30)
# WAZUH_POLL_INTERVAL=30

# SQLite system of record (default: wazuh_alerts.db in script directory)
# WAZUH_DB_PATH=wazuh_alerts.db
