# Manager API (connectivity check). Default: wazuh/wazuh
WAZUH_IP=192.168.56.103
WAZUH_USER=wazuh
WAZUH_PASS=wazuh

# Indexer (alerts). OVA default: admin/admin
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=admin

# SSH tunnel to server (indexer is on server localhost). OVA default: wazuh-user / wazuh
WAZUH_SSH_USER=wazuh-user
WAZUH_SSH_PASS=wazuh
WAZUH_SSH_KNOWN_HOSTS_PATH=C:/Users/you/.ssh/known_hosts
WAZUH_CA_CERT_PATH=C:/path/to/wazuh-root-ca.pem

# Integrity protection (required): secret used for HMAC-SHA256 of full_log
# Example: generate a long random value and keep it private
ALERT_HMAC_SECRET=replace-with-long-random-secret

# API bearer token signing secret (required for protected API routes)
API_JWT_SECRET=replace-with-long-random-jwt-signing-secret

# Dashboard login credentials used by /auth/token
DASHBOARD_AUTH_USER=admin
DASHBOARD_AUTH_PASS=replace-with-strong-password
# Optional: token lifetime in seconds (default 28800 = 8 hours)
# API_TOKEN_TTL_SECONDS=28800

# Optional fallback token for browser requests
# If set, UI can work without login. Normally leave empty and use /login.
# VITE_DASHBOARD_BEARER_TOKEN=
# Optional default username shown on login screen:
# VITE_DASHBOARD_AUTH_USER=admin

# Live mode: seconds between each poll (default 30)
# WAZUH_POLL_INTERVAL=30

# SQLite system of record (default: wazuh_alerts.db in script directory)
# WAZUH_DB_PATH=wazuh_alerts.db
